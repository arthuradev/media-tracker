<UserControl x:Class="MediaTracker.Views.EpisodesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:MediaTracker.Converters"
             xmlns:vm="clr-namespace:MediaTracker.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:EpisodesViewModel}"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
    </UserControl.Resources>

    <StackPanel>
        <Border Style="{StaticResource SurfaceCard}" Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Episodes" Style="{StaticResource SectionTitleText}"/>
                    <TextBlock Text="{Binding ProgressSummary}"
                               Style="{StaticResource BodyText}"
                               Margin="0,8,0,0"
                               Visibility="{Binding ProgressSummary, Converter={StaticResource NullToVis}}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Fetch Episode Data"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding FetchAllSeasonsCommand}"
                        Visibility="{Binding CanFetch, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <Border Style="{StaticResource ErrorBanner}"
                Padding="18,14"
                Margin="0,16,0,0"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource BannerText}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <Border Style="{StaticResource ElevatedCard}"
                Padding="22"
                Margin="0,16,0,0"
                Visibility="{Binding ShowLoadingSkeleton, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Border Style="{StaticResource SkeletonBlock}" Height="20" Width="180" Margin="0,0,0,14"/>
                <Border Style="{StaticResource SkeletonBlock}" Height="48" Margin="0,0,0,10"/>
                <Border Style="{StaticResource SkeletonBlock}" Height="48" Margin="0,0,0,10"/>
                <Border Style="{StaticResource SkeletonBlock}" Height="48"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource ElevatedCard}"
                Padding="24"
                Margin="0,16,0,0"
                Visibility="{Binding HasEpisodes, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <StackPanel>
                <TextBlock Text="No episode list yet"
                           Style="{StaticResource SectionTitleText}"/>
                <TextBlock Text="{Binding EmptyStateMessage}"
                           Style="{StaticResource BodyText}"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ItemsControl ItemsSource="{Binding Seasons}"
                      Margin="0,16,0,0"
                      Visibility="{Binding HasEpisodes, Converter={StaticResource BoolToVis}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:SeasonGroup}">
                    <Border Style="{StaticResource SurfaceCard}" Margin="0,0,0,14" Padding="0">
                        <StackPanel>
                            <Button Command="{Binding DataContext.MarkSeasonWatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SeasonHeader"
                                                Background="Transparent"
                                                CornerRadius="12,12,0,0"
                                                Padding="18,14">
                                            <DockPanel>
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                    <CheckBox IsChecked="{Binding AllWatched, Mode=OneWay}"
                                                              IsHitTestVisible="False"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding Header}"
                                                               Style="{StaticResource SectionTitleText}"
                                                               FontSize="15"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Progress}"
                                                           Style="{StaticResource CaptionText}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           DockPanel.Dock="Right"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SeasonHeader" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <ItemsControl ItemsSource="{Binding Episodes}" Margin="18,0,18,14">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:EpisodeViewModel}">
                                        <Button Command="{Binding DataContext.ToggleEpisodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Cursor="Hand"
                                                Margin="0,0,0,6">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="EpisodeRow"
                                                            Style="{StaticResource SurfaceCard}"
                                                            Padding="12,10">
                                                        <DockPanel>
                                                            <CheckBox IsChecked="{Binding IsWatched, Mode=OneWay}"
                                                                      IsHitTestVisible="False"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,10,0"
                                                                      DockPanel.Dock="Left"/>

                                                            <StackPanel DockPanel.Dock="Left">
                                                                <TextBlock FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}">
                                                                    <Run Text="Episode "/>
                                                                    <Run Text="{Binding EpisodeNumber}"/>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Title}"
                                                                           Style="{StaticResource CaptionText}"
                                                                           Margin="0,4,0,0"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Visibility="{Binding Title, Converter={StaticResource NullToVis}}"/>
                                                            </StackPanel>

                                                            <TextBlock Text="{Binding AirDate}"
                                                                       Style="{StaticResource CaptionText}"
                                                                       DockPanel.Dock="Right"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding AirDate, Converter={StaticResource NullToVis}}"/>
                                                        </DockPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="EpisodeRow" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                                                            <Setter TargetName="EpisodeRow" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>

<UserControl x:Class="MediaTracker.Views.GameProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:MediaTracker.Converters"
             xmlns:vm="clr-namespace:MediaTracker.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:GameProgressViewModel}">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:CompletionStateDisplayConverter x:Key="CompletionStateDisplay"/>

        <Style x:Key="ProgressLabel" TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource SurfaceCard}" Padding="24">
        <StackPanel>
            <TextBlock Text="Game progress" Style="{StaticResource SectionTitleText}"/>
            <TextBlock Text="Keep a lightweight log of your platform, current stage and overall completion."
                       Style="{StaticResource BodyText}"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"/>

            <Border Style="{StaticResource ErrorBanner}"
                    Margin="0,18,0,0"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Style="{StaticResource BannerText}"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Style="{StaticResource SuccessBanner}"
                    Margin="0,18,0,0"
                    Visibility="{Binding StatusMessage, Converter={StaticResource NullToVis}}">
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource BannerText}"
                           Foreground="{StaticResource SuccessBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Completion state" Style="{StaticResource ProgressLabel}"/>
                    <ComboBox ItemsSource="{Binding CompletionStates}"
                              SelectedItem="{Binding CompletionState}"
                              Style="{StaticResource InputComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource CompletionStateDisplay}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Hours played" Style="{StaticResource ProgressLabel}"/>
                    <TextBox Text="{Binding HoursPlayed, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBox}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Platform" Style="{StaticResource ProgressLabel}" Margin="0,16,0,6"/>
            <TextBox Text="{Binding Platform, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBox}"/>

            <TextBlock Text="Current stage or notes" Style="{StaticResource ProgressLabel}" Margin="0,16,0,6"/>
            <TextBox Text="{Binding CurrentStage, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputTextBox}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Height="88"
                     VerticalContentAlignment="Top"/>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="Save Progress"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource AccentButton}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

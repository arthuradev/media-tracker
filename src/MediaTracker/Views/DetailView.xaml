<UserControl x:Class="MediaTracker.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:MediaTracker.Converters"
             xmlns:vm="clr-namespace:MediaTracker.ViewModels"
             xmlns:views="clr-namespace:MediaTracker.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DetailViewModel}">

    <UserControl.Resources>
        <conv:MediaStatusDisplayConverter x:Key="StatusDisplay"/>
        <conv:MediaTypeDisplayConverter x:Key="TypeDisplay"/>
        <conv:StatusToBrushConverter x:Key="StatusBrush"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- Main content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding Item, Converter={StaticResource NullToVis}}">
            <StackPanel MaxWidth="980">

                <!-- Top bar: Back + actions -->
                <DockPanel Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="{Binding [common.edit], Source={StaticResource Loc}}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding EditCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{Binding [common.delete], Source={StaticResource Loc}}"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>

                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding GoBackCommand}"
                            DockPanel.Dock="Left"
                            FontSize="13">
                        <Button.Content>
                            <TextBlock>
                                <Run Text="&#xE72B; " FontFamily="Segoe MDL2 Assets"/>
                                <Run Text="{Binding [common.back], Source={StaticResource Loc}, Mode=OneWay}" FontFamily="{StaticResource DefaultFont}"/>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </DockPanel>

                <!-- Error banner -->
                <Border Style="{StaticResource ErrorBanner}"
                        Margin="0,0,0,16"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource BannerText}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Hero section: Cover + metadata -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cover — 200x280, radius 8 -->
                    <Border Grid.Column="0"
                            Width="200" Height="280"
                            Background="{StaticResource SurfaceBrush}"
                            CornerRadius="{StaticResource RadiusCover}"
                            ClipToBounds="True">
                        <Grid>
                            <TextBlock Text="{Binding [library.noCover], Source={StaticResource Loc}}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding Item.CoverImagePath, Converter={StaticResource NullToVis}, ConverterParameter=invert}"/>
                            <Image Source="{Binding Item.CoverImagePath}"
                                   Stretch="UniformToFill"
                                   Visibility="{Binding Item.CoverImagePath, Converter={StaticResource NullToVis}}"/>
                        </Grid>
                    </Border>

                    <!-- Metadata -->
                    <StackPanel Grid.Column="2">
                        <!-- Title — 22px/700 -->
                        <TextBlock Text="{Binding Item.Title}"
                                   Style="{StaticResource DetailTitleText}"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

                        <!-- Original title -->
                        <TextBlock Text="{Binding Item.OriginalTitle}"
                                   Style="{StaticResource CaptionText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding Item.OriginalTitle, Converter={StaticResource NullToVis}}"/>

                        <!-- Inline metadata: year · type · duration -->
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding Item.ReleaseYear}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding Item.MediaType, Converter={StaticResource TypeDisplay}}"/>
                        </TextBlock>

                        <!-- Status badge -->
                        <WrapPanel Margin="0,16,0,0">
                            <Border Background="{Binding Item.Status, Converter={StaticResource StatusBrush}}"
                                    CornerRadius="{StaticResource RadiusPill}"
                                    Padding="10,5"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding Item.Status, Converter={StaticResource StatusDisplay}}"
                                           FontSize="{StaticResource FontSizeMicro}"
                                           FontWeight="SemiBold"
                                           Foreground="#FFFFFF"/>
                            </Border>
                        </WrapPanel>

                        <!-- Stats row -->
                        <WrapPanel Margin="0,16,0,0">
                            <Border Background="{StaticResource BackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="14,10"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding Item.UserScore, Converter={StaticResource NullToVis}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding [detail.rating], Source={StaticResource Loc}}" Style="{StaticResource CaptionText}"/>
                                    <TextBlock FontSize="18" FontWeight="SemiBold"
                                               Foreground="{StaticResource StatusPausedBrush}"
                                               Margin="0,4,0,0">
                                        <Run Text="{Binding Item.UserScore}"/><Run Text="/10"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource BackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="14,10"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding Item.RuntimeMinutes, Converter={StaticResource NullToVis}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding [detail.runtime], Source={StaticResource Loc}}" Style="{StaticResource CaptionText}"/>
                                    <TextBlock Text="{Binding Item.RuntimeMinutes, StringFormat={}{0} min}"
                                               FontSize="15" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource BackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="14,10"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding Item.TotalSeasons, Converter={StaticResource NullToVis}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding [detail.seasons], Source={StaticResource Loc}}" Style="{StaticResource CaptionText}"/>
                                    <TextBlock Text="{Binding Item.TotalSeasons}"
                                               FontSize="15" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource BackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="14,10"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding Item.TotalEpisodes, Converter={StaticResource NullToVis}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding [detail.episodes], Source={StaticResource Loc}}" Style="{StaticResource CaptionText}"/>
                                    <TextBlock Text="{Binding Item.TotalEpisodes}"
                                               FontSize="15" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Genres -->
                        <TextBlock Text="{Binding Item.Genres}"
                                   Style="{StaticResource CaptionText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding Item.Genres, Converter={StaticResource NullToVis}}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- Synopsis -->
                <Border Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusCard}"
                        Padding="20"
                        Margin="0,0,0,16"
                        Visibility="{Binding Item.Synopsis, Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [detail.synopsis], Source={StaticResource Loc}}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Item.Synopsis}"
                                   Style="{StaticResource BodyText}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- User review / notes -->
                <Border Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusCard}"
                        Padding="20"
                        Margin="0,0,0,16"
                        Visibility="{Binding Item.UserReview, Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [detail.notes], Source={StaticResource Loc}}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Item.UserReview}"
                                   Style="{StaticResource BodyText}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Episodes (series/anime) -->
                <ContentControl Content="{Binding EpisodesViewModel}"
                                Margin="0,0,0,16"
                                Visibility="{Binding IsSeriesOrAnime, Converter={StaticResource BoolToVis}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:EpisodesViewModel}">
                            <views:EpisodesView DataContext="{Binding}"/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- Game progress -->
                <ContentControl Content="{Binding GameProgressViewModel}"
                                Margin="0,0,0,16"
                                Visibility="{Binding IsGame, Converter={StaticResource BoolToVis}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:GameProgressViewModel}">
                            <views:GameProgressView DataContext="{Binding}"/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading skeleton -->
        <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource SkeletonBlock}" Height="280"/>
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SkeletonBlock}" Height="28" Width="320" Margin="0,0,0,12"/>
                    <Border Style="{StaticResource SkeletonBlock}" Height="16" Width="220" Margin="0,0,0,18"/>
                    <WrapPanel>
                        <Border Style="{StaticResource SkeletonBlock}" Width="100" Height="30" Margin="0,0,12,12"/>
                        <Border Style="{StaticResource SkeletonBlock}" Width="80" Height="30" Margin="0,0,12,12"/>
                    </WrapPanel>
                    <Border Style="{StaticResource SkeletonBlock}" Height="16" Margin="0,18,0,10"/>
                    <Border Style="{StaticResource SkeletonBlock}" Height="16" Width="420"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Error / not found state -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="400"
                    Visibility="{Binding Item, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="{Binding [detail.emptyTitle], Source={StaticResource Loc}}"
                       FontSize="16" FontWeight="Medium"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding [detail.emptyMessage], Source={StaticResource Loc}}"
                       Style="{StaticResource CaptionText}"
                       Margin="0,8,0,0"
                       TextAlignment="Center"/>
            <Button Content="{Binding [detail.backToLibrary], Source={StaticResource Loc}}"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding GoBackCommand}"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="MediaTracker.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:MediaTracker.Converters"
             xmlns:vm="clr-namespace:MediaTracker.ViewModels"
             xmlns:views="clr-namespace:MediaTracker.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DetailViewModel}">

    <UserControl.Resources>
        <conv:MediaStatusDisplayConverter x:Key="StatusDisplay"/>
        <conv:MediaTypeDisplayConverter x:Key="TypeDisplay"/>
        <conv:StatusToBrushConverter x:Key="StatusBrush"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding Item, Converter={StaticResource NullToVis}}">
            <StackPanel MaxWidth="980">
                <DockPanel Margin="0,0,0,18">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="Edit"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding EditCommand}"
                                Margin="0,0,10,0"/>
                        <Button Content="Delete"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>

                    <Button Content="Back"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding GoBackCommand}"
                            DockPanel.Dock="Left"/>
                </DockPanel>

                <Border Style="{StaticResource ErrorBanner}"
                        Margin="0,0,0,18"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource BannerText}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <Border Style="{StaticResource ElevatedCard}" Padding="26">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource SurfaceCard}"
                                Height="320"
                                ClipToBounds="True">
                            <Grid>
                                <Border Background="{StaticResource SurfaceRaisedBrush}"/>
                                <TextBlock Text="No cover available"
                                           Style="{StaticResource CaptionText}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Item.CoverImagePath, Converter={StaticResource NullToVis}, ConverterParameter=invert}"/>
                                <Image Source="{Binding Item.CoverImagePath}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding Item.CoverImagePath, Converter={StaticResource NullToVis}}"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="24,0,0,0">
                            <TextBlock Text="{Binding Item.Title}"
                                       Style="{StaticResource PageTitleText}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding Item.OriginalTitle}"
                                       Style="{StaticResource BodyText}"
                                       Margin="0,8,0,0"
                                       Visibility="{Binding Item.OriginalTitle, Converter={StaticResource NullToVis}}"/>

                            <WrapPanel Margin="0,16,0,0">
                                <Border Background="{Binding Item.Status, Converter={StaticResource StatusBrush}}"
                                        CornerRadius="10"
                                        Padding="10,6"
                                        Margin="0,0,10,10">
                                    <TextBlock Text="{Binding Item.Status, Converter={StaticResource StatusDisplay}}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BackgroundDarkBrush}"/>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}" Padding="10,6" Margin="0,0,10,10">
                                    <TextBlock Text="{Binding Item.MediaType, Converter={StaticResource TypeDisplay}}"
                                               Style="{StaticResource CaptionText}"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}"
                                        Padding="10,6"
                                        Margin="0,0,10,10"
                                        Visibility="{Binding Item.ReleaseYear, Converter={StaticResource NullToVis}}">
                                    <TextBlock Text="{Binding Item.ReleaseYear}"
                                               Style="{StaticResource CaptionText}"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                            </WrapPanel>

                            <WrapPanel Margin="0,8,0,0">
                                <Border Style="{StaticResource SurfaceCard}"
                                        Padding="14,12"
                                        Margin="0,0,12,12"
                                        Visibility="{Binding Item.UserScore, Converter={StaticResource NullToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Your rating" Style="{StaticResource CaptionText}"/>
                                        <TextBlock FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource WarningBrush}">
                                            <Run Text="&#x2605; "/>
                                            <Run Text="{Binding Item.UserScore}"/>
                                            <Run Text="/10"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}"
                                        Padding="14,12"
                                        Margin="0,0,12,12"
                                        Visibility="{Binding Item.RuntimeMinutes, Converter={StaticResource NullToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Runtime" Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding Item.RuntimeMinutes, StringFormat={}{0} min}"
                                                   Style="{StaticResource SectionTitleText}"
                                                   FontSize="15"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}"
                                        Padding="14,12"
                                        Margin="0,0,12,12"
                                        Visibility="{Binding Item.TotalSeasons, Converter={StaticResource NullToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Seasons" Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding Item.TotalSeasons}"
                                                   Style="{StaticResource SectionTitleText}"
                                                   FontSize="15"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}"
                                        Padding="14,12"
                                        Margin="0,0,12,12"
                                        Visibility="{Binding Item.TotalEpisodes, Converter={StaticResource NullToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Episodes" Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding Item.TotalEpisodes}"
                                                   Style="{StaticResource SectionTitleText}"
                                                   FontSize="15"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <TextBlock Text="{Binding Item.Genres}"
                                       Style="{StaticResource BodyText}"
                                       Margin="0,6,0,0"
                                       Visibility="{Binding Item.Genres, Converter={StaticResource NullToVis}}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SurfaceCard}"
                        Padding="24"
                        Margin="0,18,0,0"
                        Visibility="{Binding Item.Synopsis, Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <TextBlock Text="Synopsis" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding Item.Synopsis}"
                                   Style="{StaticResource BodyText}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SurfaceCard}"
                        Padding="24"
                        Margin="0,18,0,0"
                        Visibility="{Binding Item.UserReview, Converter={StaticResource NullToVis}}">
                    <StackPanel>
                        <TextBlock Text="Your review" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="{Binding Item.UserReview}"
                                   Style="{StaticResource BodyText}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <ContentControl Content="{Binding EpisodesViewModel}"
                                Margin="0,18,0,0"
                                Visibility="{Binding IsSeriesOrAnime, Converter={StaticResource BoolToVis}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:EpisodesViewModel}">
                            <views:EpisodesView DataContext="{Binding}"/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <ContentControl Content="{Binding GameProgressViewModel}"
                                Margin="0,18,0,0"
                                Visibility="{Binding IsGame, Converter={StaticResource BoolToVis}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:GameProgressViewModel}">
                            <views:GameProgressView DataContext="{Binding}"/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource ElevatedCard}" Padding="26">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SkeletonBlock}" Height="320" Margin="0,0,20,0"/>
                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource SkeletonBlock}" Height="28" Width="320" Margin="0,0,0,12"/>
                        <Border Style="{StaticResource SkeletonBlock}" Height="16" Width="220" Margin="0,0,0,18"/>
                        <WrapPanel>
                            <Border Style="{StaticResource SkeletonBlock}" Width="110" Height="34" Margin="0,0,12,12"/>
                            <Border Style="{StaticResource SkeletonBlock}" Width="90" Height="34" Margin="0,0,12,12"/>
                            <Border Style="{StaticResource SkeletonBlock}" Width="90" Height="34" Margin="0,0,12,12"/>
                        </WrapPanel>
                        <Border Style="{StaticResource SkeletonBlock}" Height="16" Margin="0,18,0,10"/>
                        <Border Style="{StaticResource SkeletonBlock}" Height="16" Width="420" Margin="0,0,0,10"/>
                        <Border Style="{StaticResource SkeletonBlock}" Height="16" Width="320"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,18,0,0">
                <StackPanel>
                    <Border Style="{StaticResource SkeletonBlock}" Height="20" Width="140" Margin="0,0,0,12"/>
                    <Border Style="{StaticResource SkeletonBlock}" Height="14" Margin="0,0,0,10"/>
                    <Border Style="{StaticResource SkeletonBlock}" Height="14" Margin="0,0,0,10"/>
                    <Border Style="{StaticResource SkeletonBlock}" Height="14" Width="520"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Padding="28"
                MaxWidth="540"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding Item, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ElevatedCard}">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="Nothing to show here yet"
                           Style="{StaticResource SectionTitleText}"
                           FontSize="{StaticResource FontSizeLarge}"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Style="{StaticResource BodyText}"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"/>
                <TextBlock Text="The selected item could not be loaded. Try returning to the library and opening it again."
                           Style="{StaticResource BodyText}"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
                <Button Content="Back to Library"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding GoBackCommand}"
                        Margin="0,22,0,0"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

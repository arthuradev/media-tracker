<UserControl x:Class="MediaTracker.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:conv="clr-namespace:MediaTracker.Converters"
             xmlns:models="clr-namespace:MediaTracker.Models"
             xmlns:vm="clr-namespace:MediaTracker.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LibraryViewModel}"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:MediaStatusDisplayConverter x:Key="StatusDisplay"/>
        <conv:MediaTypeDisplayConverter x:Key="TypeDisplay"/>
        <conv:StatusToBrushConverter x:Key="StatusBrush"/>
        <conv:ScoreToStarsConverter x:Key="ScoreDisplay"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EqualityToStyleConverter x:Key="EqualityToStyle"/>

        <x:Array Type="{x:Type sys:Int32}" x:Key="SkeletonCards">
            <sys:Int32>1</sys:Int32>
            <sys:Int32>2</sys:Int32>
            <sys:Int32>3</sys:Int32>
            <sys:Int32>4</sys:Int32>
            <sys:Int32>5</sys:Int32>
            <sys:Int32>6</sys:Int32>
            <sys:Int32>7</sys:Int32>
            <sys:Int32>8</sys:Int32>
        </x:Array>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="STATUS FILTERS"
                       Style="{StaticResource PageEyebrowText}"
                       Margin="6,0,0,10"/>

            <WrapPanel>
                <Button Content="All"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Null}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Plan to Watch"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.PlanToWatch}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Watching"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.Watching}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Completed"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.Completed}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Paused"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.Paused}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Dropped"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.Dropped}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>
            </WrapPanel>

            <TextBlock Text="LAYOUT"
                       Style="{StaticResource PageEyebrowText}"
                       Margin="6,16,0,10"/>

            <WrapPanel>
                <Button Content="Grid"
                        Command="{Binding SetDisplayModeCommand}"
                        CommandParameter="{x:Static models:LibraryDisplayMode.Grid}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="DisplayMode"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="List"
                        Command="{Binding SetDisplayModeCommand}"
                        CommandParameter="{x:Static models:LibraryDisplayMode.List}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="DisplayMode"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>
            </WrapPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource ErrorBanner}"
                Margin="0,0,0,16"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource BannerText}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding ShowLoadingSkeleton, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{StaticResource SkeletonCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SurfaceCard}"
                                    Width="196"
                                    Height="360"
                                    Margin="0,0,16,16"
                                    Padding="0">
                                <StackPanel>
                                    <Border Style="{StaticResource SkeletonBlock}"
                                            Height="262"
                                            CornerRadius="12,12,0,0"/>
                                    <StackPanel Margin="14,14,14,0">
                                        <Border Style="{StaticResource SkeletonBlock}" Height="18" Margin="0,0,0,10"/>
                                        <Border Style="{StaticResource SkeletonBlock}" Height="12" Width="120" Margin="0,0,0,8"/>
                                        <Border Style="{StaticResource SkeletonBlock}" Height="12" Width="96"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Style="{StaticResource ElevatedCard}"
                    Padding="34"
                    MaxWidth="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding EmptyTitle}"
                               Style="{StaticResource PageTitleText}"
                               FontSize="{StaticResource FontSizeLarge}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding EmptyMessage}"
                               Style="{StaticResource BodyText}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                    <Button Content="Add Media"
                            Command="{Binding AddNewCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="0,22,0,0"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEmpty}" Value="False"/>
                                    <Condition Binding="{Binding IsGridMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MediaCardViewModel}">
                            <Button Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Id}"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,16,16">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Card"
                                                Style="{StaticResource SurfaceCard}"
                                                Width="196"
                                                Background="{StaticResource SurfaceBrush}"
                                                ClipToBounds="True">
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="CardTransform"/>
                                            </Border.RenderTransform>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="262"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Border Background="{StaticResource SurfaceRaisedBrush}"/>

                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding CoverImagePath, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
                                                        <TextBlock Text="No cover"
                                                                   Style="{StaticResource SectionTitleText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Imported titles cache artwork here when it is available."
                                                                   Style="{StaticResource CaptionText}"
                                                                   Margin="18,8,18,0"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <Image Source="{Binding CoverImagePath}"
                                                           Stretch="UniformToFill"
                                                           Visibility="{Binding CoverImagePath, Converter={StaticResource NullToVis}}"/>

                                                    <Border Background="#52091522"
                                                            Height="90"
                                                            VerticalAlignment="Bottom"/>

                                                    <Border Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                                                            CornerRadius="8"
                                                            Padding="8,4"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Margin="12">
                                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusDisplay}}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource BackgroundDarkBrush}"/>
                                                    </Border>

                                                    <Border Background="#9A07111F"
                                                            BorderBrush="{StaticResource BorderStrongBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="8,4"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="12"
                                                            Visibility="{Binding UserScore, Converter={StaticResource NullToVis}}">
                                                        <TextBlock Text="{Binding UserScore, Converter={StaticResource ScoreDisplay}}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource WarningBrush}"/>
                                                    </Border>
                                                </Grid>

                                                <StackPanel Grid.Row="1" Margin="14,14,14,16">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource SectionTitleText}"
                                                               FontSize="15"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="44"/>

                                                    <TextBlock Margin="0,6,0,0"
                                                               Style="{StaticResource CaptionText}">
                                                        <Run Text="{Binding ReleaseYear}"/>
                                                        <Run Text="  "/>
                                                        <Run Text="{Binding MediaType, Converter={StaticResource TypeDisplay}}"/>
                                                    </TextBlock>

                                                    <TextBlock Text="{Binding Genres}"
                                                               Style="{StaticResource CaptionText}"
                                                               Margin="0,8,0,0"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="34"
                                                               Visibility="{Binding Genres, Converter={StaticResource NullToVis}}"/>

                                                    <Border Background="{StaticResource AccentSoftBrush}"
                                                            CornerRadius="9"
                                                            Padding="10,6"
                                                            Margin="0,12,0,0"
                                                            Visibility="{Binding ProgressText, Converter={StaticResource NullToVis}}">
                                                        <TextBlock Text="{Binding ProgressText}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentHoverBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CardTransform"
                                                                         Storyboard.TargetProperty="Y"
                                                                         To="-6"
                                                                         Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CardTransform"
                                                                         Storyboard.TargetProperty="Y"
                                                                         To="0"
                                                                         Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Card" Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEmpty}" Value="False"/>
                                    <Condition Binding="{Binding IsListMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MediaCardViewModel}">
                            <Button Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Id}"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,0,14"
                                    HorizontalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ListCard"
                                                Style="{StaticResource SurfaceCard}"
                                                Background="{StaticResource SurfaceBrush}"
                                                Padding="16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="96"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Style="{StaticResource SurfaceCard}"
                                                        Background="{StaticResource SurfaceRaisedBrush}"
                                                        Width="96"
                                                        Height="136"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <TextBlock Text="No cover"
                                                                   Style="{StaticResource CaptionText}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding CoverImagePath, Converter={StaticResource NullToVis}, ConverterParameter=invert}"/>
                                                        <Image Source="{Binding CoverImagePath}"
                                                               Stretch="UniformToFill"
                                                               Visibility="{Binding CoverImagePath, Converter={StaticResource NullToVis}}"/>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="2">
                                                    <DockPanel LastChildFill="False">
                                                        <StackPanel DockPanel.Dock="Left" Margin="0,0,16,0">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Style="{StaticResource SectionTitleText}"
                                                                       FontSize="18"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxHeight="48"/>

                                                            <TextBlock Margin="0,6,0,0"
                                                                       Style="{StaticResource CaptionText}">
                                                                <Run Text="{Binding ReleaseYear}"/>
                                                                <Run Text="  "/>
                                                                <Run Text="{Binding MediaType, Converter={StaticResource TypeDisplay}}"/>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <Border Background="#9A07111F"
                                                                BorderBrush="{StaticResource BorderStrongBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="9"
                                                                Padding="10,6"
                                                                DockPanel.Dock="Right"
                                                                Visibility="{Binding UserScore, Converter={StaticResource NullToVis}}">
                                                            <TextBlock Text="{Binding UserScore, Converter={StaticResource ScoreDisplay}}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource WarningBrush}"/>
                                                        </Border>
                                                    </DockPanel>

                                                    <WrapPanel Margin="0,12,0,0">
                                                        <Border Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                                                                CornerRadius="8"
                                                                Padding="9,5"
                                                                Margin="0,0,10,10">
                                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusDisplay}}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource BackgroundDarkBrush}"/>
                                                        </Border>

                                                        <Border Style="{StaticResource SurfaceCard}"
                                                                Padding="9,5"
                                                                Margin="0,0,10,10">
                                                            <TextBlock Text="{Binding MediaType, Converter={StaticResource TypeDisplay}}"
                                                                       Style="{StaticResource CaptionText}"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </Border>

                                                        <Border Style="{StaticResource SurfaceCard}"
                                                                Padding="9,5"
                                                                Margin="0,0,10,10"
                                                                Visibility="{Binding ReleaseYear, Converter={StaticResource NullToVis}}">
                                                            <TextBlock Text="{Binding ReleaseYear}"
                                                                       Style="{StaticResource CaptionText}"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </Border>
                                                    </WrapPanel>

                                                    <TextBlock Text="{Binding Genres}"
                                                               Style="{StaticResource BodyText}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="44"
                                                               Visibility="{Binding Genres, Converter={StaticResource NullToVis}}"/>

                                                    <Border Background="{StaticResource AccentSoftBrush}"
                                                            CornerRadius="10"
                                                            Padding="12,8"
                                                            Margin="0,14,0,0"
                                                            HorizontalAlignment="Left"
                                                            Visibility="{Binding ProgressText, Converter={StaticResource NullToVis}}">
                                                        <TextBlock Text="{Binding ProgressText}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentHoverBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ListCard" Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                <Setter TargetName="ListCard" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

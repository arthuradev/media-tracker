<UserControl x:Class="MediaTracker.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:conv="clr-namespace:MediaTracker.Converters"
             xmlns:models="clr-namespace:MediaTracker.Models"
             xmlns:vm="clr-namespace:MediaTracker.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LibraryViewModel}"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:MediaStatusDisplayConverter x:Key="StatusDisplay"/>
        <conv:MediaTypeDisplayConverter x:Key="TypeDisplay"/>
        <conv:StatusToBrushConverter x:Key="StatusBrush"/>
        <conv:ScoreToStarsConverter x:Key="ScoreDisplay"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EqualityToStyleConverter x:Key="EqualityToStyle"/>

        <x:Array Type="{x:Type sys:Int32}" x:Key="SkeletonCards">
            <sys:Int32>1</sys:Int32><sys:Int32>2</sys:Int32><sys:Int32>3</sys:Int32><sys:Int32>4</sys:Int32>
            <sys:Int32>5</sys:Int32><sys:Int32>6</sys:Int32><sys:Int32>7</sys:Int32><sys:Int32>8</sys:Int32>
            <sys:Int32>9</sys:Int32><sys:Int32>10</sys:Int32>
        </x:Array>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="Auto"/>  <!-- Error banner -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- FILTER BAR — status pills + layout toggle               -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status filter pills -->
            <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                <Button Content="All"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Null}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Plan to Watch"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.PlanToWatch}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Watching"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.Watching}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Completed"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.Completed}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Paused"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.Paused}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="Dropped"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="{x:Static models:MediaStatus.Dropped}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="StatusFilter"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>
            </WrapPanel>

            <!-- Layout toggle -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Grid"
                        Command="{Binding SetDisplayModeCommand}"
                        CommandParameter="{x:Static models:LibraryDisplayMode.Grid}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="DisplayMode"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>

                <Button Content="List"
                        Command="{Binding SetDisplayModeCommand}"
                        CommandParameter="{x:Static models:LibraryDisplayMode.List}">
                    <Button.Style>
                        <MultiBinding Converter="{StaticResource EqualityToStyle}">
                            <Binding Path="DisplayMode"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                            <Binding Source="{StaticResource StatusPillActive}"/>
                            <Binding Source="{StaticResource StatusPill}"/>
                        </MultiBinding>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Error banner -->
        <Border Grid.Row="1"
                Style="{StaticResource ErrorBanner}"
                Margin="0,0,0,16"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource BannerText}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONTENT AREA                                           -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- Skeleton loading -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding ShowLoadingSkeleton, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{StaticResource SkeletonCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="200" Margin="0,0,16,16">
                                <StackPanel>
                                    <Border Style="{StaticResource SkeletonBlock}"
                                            Height="280"
                                            CornerRadius="{StaticResource RadiusCover}"/>
                                    <StackPanel Margin="0,10,0,0">
                                        <Border Style="{StaticResource SkeletonBlock}" Height="16" Margin="0,0,0,8"/>
                                        <Border Style="{StaticResource SkeletonBlock}" Height="12" Width="120"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="400"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding EmptyTitle}"
                           Style="{StaticResource HeroText}"
                           FontSize="16"
                           FontWeight="Medium"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding EmptyMessage}"
                           Style="{StaticResource CaptionText}"
                           Margin="0,8,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button Content="+ Add"
                        Command="{Binding AddNewCommand}"
                        Style="{StaticResource AccentButton}"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- GRID MODE — Vault cards                             -->
            <!-- ═══════════════════════════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEmpty}" Value="False"/>
                                    <Condition Binding="{Binding IsGridMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MediaCardViewModel}">
                            <Button Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Id}"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,16,16">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Card"
                                                Width="200"
                                                Background="Transparent">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>  <!-- Cover -->
                                                    <RowDefinition Height="72"/>    <!-- Info block -->
                                                </Grid.RowDefinitions>

                                                <!-- Cover — 2:3 ratio (200x280) -->
                                                <Grid Grid.Row="0">
                                                    <Border x:Name="CoverBorder"
                                                            Height="280"
                                                            Background="{StaticResource SurfaceBrush}"
                                                            CornerRadius="{StaticResource RadiusCover}"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <!-- No cover placeholder -->
                                                            <TextBlock Text="No cover"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="12"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding CoverImagePath, Converter={StaticResource NullToVis}, ConverterParameter=invert}"/>

                                                            <Image Source="{Binding CoverImagePath}"
                                                                   Stretch="UniformToFill"
                                                                   Visibility="{Binding CoverImagePath, Converter={StaticResource NullToVis}}"/>

                                                            <!-- Hover overlay -->
                                                            <Border x:Name="HoverOverlay"
                                                                    Background="#4D000000"
                                                                    Opacity="0"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Status badge — bottom-left of cover -->
                                                    <Border Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                                                            CornerRadius="{StaticResource RadiusPill}"
                                                            Padding="8,3"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Bottom"
                                                            Margin="8,0,0,8">
                                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusDisplay}}"
                                                                   FontSize="{StaticResource FontSizeMicro}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FFFFFF"/>
                                                    </Border>

                                                    <!-- Score badge — top-right -->
                                                    <Border Background="#B0111113"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource RadiusPill}"
                                                            Padding="8,3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="0,8,8,0"
                                                            Visibility="{Binding UserScore, Converter={StaticResource NullToVis}}">
                                                        <TextBlock Text="{Binding UserScore, Converter={StaticResource ScoreDisplay}}"
                                                                   FontSize="{StaticResource FontSizeMicro}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource StatusPausedBrush}"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Progress bar — 3px, above info block -->
                                                <Border Grid.Row="0"
                                                        VerticalAlignment="Bottom"
                                                        Height="3"
                                                        Background="#14FFFFFF"
                                                        CornerRadius="0,0,0,0"
                                                        Visibility="{Binding ProgressText, Converter={StaticResource NullToVis}}">
                                                    <Border Background="{StaticResource StatusWatchingBrush}"
                                                            CornerRadius="2"
                                                            HorizontalAlignment="Left"
                                                            Width="{Binding ProgressRatio, FallbackValue=0}"/>
                                                </Border>

                                                <!-- Info block — 72px, no padding, aligned with cover edges -->
                                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                                    <!-- Title — 13px/600, max 2 lines -->
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource LabelText}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="36"/>

                                                    <!-- Year · Genre -->
                                                    <TextBlock Margin="0,4,0,0"
                                                               Style="{StaticResource CaptionText}">
                                                        <Run Text="{Binding ReleaseYear}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding Genres, FallbackValue=''}"/>
                                                    </TextBlock>

                                                    <!-- Episode progress text -->
                                                    <TextBlock Text="{Binding ProgressText}"
                                                               FontSize="{StaticResource FontSizeMicro}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding ProgressText, Converter={StaticResource NullToVis}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- LIST MODE                                           -->
            <!-- ═══════════════════════════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEmpty}" Value="False"/>
                                    <Condition Binding="{Binding IsListMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MediaCardViewModel}">
                            <Button Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Id}"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,0,2"
                                    HorizontalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ListRow"
                                                Background="Transparent"
                                                CornerRadius="{StaticResource RadiusMedium}"
                                                Padding="12,8"
                                                Height="64">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>  <!-- Thumbnail -->
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>   <!-- Title + meta -->
                                                    <ColumnDefinition Width="Auto"/><!-- Status -->
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="Auto"/><!-- Score -->
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="Auto"/><!-- Progress -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Thumbnail 40x60 -->
                                                <Border Grid.Column="0"
                                                        Width="40" Height="60"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        CornerRadius="4"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Center">
                                                    <Image Source="{Binding CoverImagePath}"
                                                           Stretch="UniformToFill"
                                                           Visibility="{Binding CoverImagePath, Converter={StaticResource NullToVis}}"/>
                                                </Border>

                                                <!-- Title + meta -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource LabelText}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Margin="0,2,0,0"
                                                               Style="{StaticResource CaptionText}">
                                                        <Run Text="{Binding ReleaseYear}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding MediaType, Converter={StaticResource TypeDisplay}}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Status badge -->
                                                <Border Grid.Column="3"
                                                        Background="{Binding Status, Converter={StaticResource StatusBrush}}"
                                                        CornerRadius="{StaticResource RadiusPill}"
                                                        Padding="8,3"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusDisplay}}"
                                                               FontSize="{StaticResource FontSizeMicro}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#FFFFFF"/>
                                                </Border>

                                                <!-- Score -->
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding UserScore, Converter={StaticResource ScoreDisplay}}"
                                                           Style="{StaticResource CaptionText}"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding UserScore, Converter={StaticResource NullToVis}}"/>

                                                <!-- Progress -->
                                                <TextBlock Grid.Column="7"
                                                           Text="{Binding ProgressText}"
                                                           Style="{StaticResource CaptionText}"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding ProgressText, Converter={StaticResource NullToVis}}"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ListRow" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

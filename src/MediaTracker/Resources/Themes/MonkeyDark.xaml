<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        MONKEY DARK — Media Tracker
        Inspired by Monkeytype's contemplative, typographic aesthetic.
        Neutral charcoal palette · warm off-white text · single accent.
        Swap this file for a different palette to re-theme the entire app.
    -->

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- PALETTE — raw colours (never reference these directly)     -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <Color x:Key="BackgroundDarkColor">#1a1a1e</Color>
    <Color x:Key="BackgroundColor">#232326</Color>
    <Color x:Key="SurfaceColor">#2c2c30</Color>
    <Color x:Key="SurfaceLightColor">#343438</Color>
    <Color x:Key="SurfaceRaisedColor">#3c3c41</Color>

    <Color x:Key="BorderColor">#3c3c41</Color>
    <Color x:Key="BorderStrongColor">#505057</Color>

    <Color x:Key="TextPrimaryColor">#d1d0c5</Color>
    <Color x:Key="TextSecondaryColor">#646669</Color>
    <Color x:Key="TextMutedColor">#444449</Color>

    <Color x:Key="AccentColor">#e2b714</Color>
    <Color x:Key="AccentHoverColor">#ebc934</Color>
    <Color x:Key="AccentSoftColor">#2a2510</Color>

    <Color x:Key="SuccessColor">#7ec984</Color>
    <Color x:Key="WarningColor">#e7c468</Color>
    <Color x:Key="DangerColor">#ca4754</Color>

    <Color x:Key="OverlayColor">#CC151518</Color>
    <Color x:Key="SkeletonColor">#34343a</Color>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- SEMANTIC BRUSHES — use these in styles and views           -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="BackgroundDarkBrush"  Color="{StaticResource BackgroundDarkColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush"       Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"          Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush"     Color="{StaticResource SurfaceLightColor}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush"    Color="{StaticResource SurfaceRaisedColor}"/>

    <SolidColorBrush x:Key="BorderBrush"           Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush"     Color="{StaticResource BorderStrongColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"      Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"    Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"        Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="AccentBrush"           Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"      Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentSoftBrush"       Color="{StaticResource AccentSoftColor}"/>

    <SolidColorBrush x:Key="SuccessBrush"          Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"          Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush"           Color="{StaticResource DangerColor}"/>

    <SolidColorBrush x:Key="OverlayBrush"          Color="{StaticResource OverlayColor}"/>
    <SolidColorBrush x:Key="SkeletonBrush"         Color="{StaticResource SkeletonColor}"/>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- TYPOGRAPHY TOKENS                                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Display font: monospace for personality (headings, stats, nav) -->
    <FontFamily x:Key="DisplayFont">Cascadia Code, Consolas, Courier New</FontFamily>

    <!-- Body font: clean sans-serif for readability -->
    <FontFamily x:Key="DefaultFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>

    <sys:Double x:Key="FontSizeTiny">11</sys:Double>
    <sys:Double x:Key="FontSizeSmall">12</sys:Double>
    <sys:Double x:Key="FontSizeNormal">13.5</sys:Double>
    <sys:Double x:Key="FontSizeMedium">16</sys:Double>
    <sys:Double x:Key="FontSizeLarge">22</sys:Double>
    <sys:Double x:Key="FontSizeXLarge">32</sys:Double>
    <sys:Double x:Key="FontSizeHero">42</sys:Double>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- SPACING / RADIUS TOKENS                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">6</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">10</CornerRadius>

    <Thickness x:Key="SpacingTiny">4</Thickness>
    <Thickness x:Key="SpacingSmall">8</Thickness>
    <Thickness x:Key="SpacingMedium">16</Thickness>
    <Thickness x:Key="SpacingLarge">24</Thickness>
    <Thickness x:Key="SpacingXLarge">40</Thickness>
    <Thickness x:Key="SpacingHuge">64</Thickness>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- ANIMATION                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <Storyboard x:Key="SkeletonPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0.3" To="0.7"
                         Duration="0:0:1.0"/>
    </Storyboard>

</ResourceDictionary>

<Window x:Class="MediaTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MediaTracker.ViewModels"
        xmlns:conv="clr-namespace:MediaTracker.Converters"
        xmlns:models="clr-namespace:MediaTracker.Models"
        mc:Ignorable="d"
        Title="Media Tracker"
        Height="900"
        Width="1440"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:MediaTypeDisplayConverter x:Key="TypeDisplay"/>

        <!-- Nav link — Vault sidebar style: 36px height, radius 6 -->
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Padding"     Value="12,0"/>
            <Setter Property="Margin"      Value="0,1"/>
            <Setter Property="Tag"         Value="{Binding DataContext.CurrentSection, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Style.Triggers>
                <!-- Active state: violet text + subtle violet background -->
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding>
                            <MultiBinding.Converter>
                                <conv:EqualityConverter/>
                            </MultiBinding.Converter>
                            <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundDarkBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SIDEBAR — #0D0D0F, recedes behind content              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">
            <Grid Margin="16,16,16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top: brand + navigation -->
                <StackPanel Grid.Row="0">
                    <!-- Brand -->
                    <TextBlock Text="{Binding [app.brand], Source={StaticResource Loc}}"
                               FontFamily="{StaticResource DefaultFont}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="12,8,0,24"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="{x:Static models:AppSection.Home}"
                            Content="{Binding [nav.home], Source={StaticResource Loc}}"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="{x:Static models:AppSection.Library}"
                            Content="{Binding [nav.library], Source={StaticResource Loc}}"/>

                    <!-- Separator -->
                    <Border Height="1"
                            Background="{StaticResource BorderBrush}"
                            Margin="12,12,12,8"/>

                    <!-- Category label -->
                    <TextBlock Text="{Binding [nav.categories], Source={StaticResource Loc}}"
                               Style="{StaticResource PageEyebrowText}"
                               Margin="12,4,0,8"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="{x:Static models:AppSection.Movies}"
                            Content="{Binding [nav.movies], Source={StaticResource Loc}}"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="{x:Static models:AppSection.Series}"
                            Content="{Binding [nav.series], Source={StaticResource Loc}}"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="{x:Static models:AppSection.Anime}"
                            Content="{Binding [nav.anime], Source={StaticResource Loc}}"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="{x:Static models:AppSection.Games}"
                            Content="{Binding [nav.games], Source={StaticResource Loc}}"/>

                    <!-- Separator -->
                    <Border Height="1"
                            Background="{StaticResource BorderBrush}"
                            Margin="12,12,12,8"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="{x:Static models:AppSection.Favorites}"
                            Content="{Binding [nav.favorites], Source={StaticResource Loc}}"/>
                </StackPanel>

                <Button Grid.Row="1"
                        Style="{StaticResource NavButton}"
                        Command="{Binding NavigateToCommand}"
                        CommandParameter="{x:Static models:AppSection.Settings}"
                        Content="{Binding [nav.settings], Source={StaticResource Loc}}"
                        FontSize="13"
                        Foreground="{StaticResource TextMutedBrush}"
                        Margin="0,16,0,0"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONTENT AREA                                           -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>   <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Update banner -->
                <RowDefinition Height="*"/>    <!-- Content host -->
            </Grid.RowDefinitions>

            <!-- Header — 56px, title + subtitle + actions -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundDarkBrush}"
                    Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Section title -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentSectionTitle}"
                               Style="{StaticResource PageTitleText}"/>

                    <!-- Item count subtitle -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding CurrentSectionSubtitle}"
                               Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center"
                               Margin="12,2,0,0"/>

                    <!-- Library search box -->
                    <TextBox x:Name="LibrarySearchBox"
                             Grid.Column="3"
                             Width="260"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{Binding [shell.searchPlaceholder], Source={StaticResource Loc}}"
                             IsVisibleChanged="OnLibrarySearchVisible">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource SearchBox}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding CanSearch}" Value="True"/>
                                            <Condition Binding="{Binding IsInlineSearchOpen}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- + Add button -->
                    <Button Grid.Column="4"
                            VerticalAlignment="Center"
                            Command="{Binding ToggleInlineSearchCommand}"
                            Content="{Binding [common.add], Source={StaticResource Loc}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding CanAddNew}" Value="True"/>
                                            <Condition Binding="{Binding IsInlineSearchOpen}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Inline search overlay (replaces search + add button) -->
                    <Grid Grid.Column="3"
                          Grid.ColumnSpan="2"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding CanAddNew}" Value="True"/>
                                            <Condition Binding="{Binding IsInlineSearchOpen}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InlineSearchBox"
                                 Grid.Column="0"
                                 Style="{StaticResource InlineSearchBox}"
                                 Tag="{Binding [shell.inlineSearchPlaceholder], Source={StaticResource Loc}}"
                                 Text="{Binding InlineSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="OnInlineSearchKeyDown"
                                 IsVisibleChanged="OnInlineSearchVisible"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding CloseInlineSearchCommand}"
                                Content="{Binding [common.esc], Source={StaticResource Loc}}"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"/>

                        <!-- Results popup -->
                        <Popup PlacementTarget="{Binding ElementName=InlineSearchBox}"
                               Placement="Bottom"
                               IsOpen="{Binding ShowInlineResults}"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               PopupAnimation="Fade"
                               HorizontalOffset="0"
                               VerticalOffset="6">
                            <Border Background="{StaticResource SurfaceLightBrush}"
                                    BorderBrush="{StaticResource BorderStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusCard}"
                                    MinWidth="420"
                                    MaxHeight="440"
                                    Padding="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding [common.searching], Source={StaticResource Loc}}"
                                               Style="{StaticResource CaptionText}"
                                               Margin="10,6,10,8"
                                               Visibility="{Binding IsInlineSearching, Converter={StaticResource BoolToVis}}"/>

                                    <TextBlock Text="{Binding InlineError}"
                                               Style="{StaticResource CaptionText}"
                                               Foreground="{StaticResource DangerBrush}"
                                               Margin="10,6,10,8"
                                               Visibility="{Binding InlineError, Converter={StaticResource NullToVis}}"/>

                                    <TextBlock Text="{Binding [common.noResults], Source={StaticResource Loc}}"
                                               Style="{StaticResource CaptionText}"
                                               Margin="10,6,10,8"
                                               Visibility="{Binding ShowInlineEmpty, Converter={StaticResource BoolToVis}}"/>

                                    <ListBox x:Name="InlineResultsList"
                                             ItemsSource="{Binding InlineResults}"
                                             SelectedItem="{Binding SelectedInlineResult, Mode=TwoWay}"
                                             Style="{StaticResource InlineResultsList}"
                                             ItemContainerStyle="{StaticResource InlineResultsListItem}"
                                             MaxHeight="320"
                                             Margin="0,0,0,2"
                                             PreviewKeyDown="OnInlineSearchKeyDown"
                                             PreviewMouseLeftButtonUp="OnInlineResultMouseLeftButtonUp">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,10,12,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="36"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Thumbnail 36x54 per spec -->
                                                        <Border Grid.Column="0"
                                                                Width="36"
                                                                Height="54"
                                                                Background="{StaticResource SurfaceBrush}"
                                                                CornerRadius="4"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <Image Source="{Binding CoverImageUrl}"
                                                                       Stretch="UniformToFill"
                                                                       Visibility="{Binding CoverImageUrl, Converter={StaticResource NullToVis}}"/>
                                                            </Grid>
                                                        </Border>

                                                        <StackPanel Grid.Column="2"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Style="{StaticResource LabelText}"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <StackPanel Orientation="Horizontal"
                                                                        Margin="0,4,0,0">
                                                                <TextBlock Text="{Binding ReleaseYear}"
                                                                           Style="{StaticResource CaptionText}"
                                                                           Visibility="{Binding ReleaseYear, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text=" · "
                                                                           Style="{StaticResource CaptionText}"
                                                                           Visibility="{Binding ReleaseYear, Converter={StaticResource NullToVis}}"/>
                                                                <TextBlock Text="{Binding MediaType, Converter={StaticResource TypeDisplay}}"
                                                                           Style="{StaticResource CaptionText}"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding ProviderName}"
                                                                   Style="{StaticResource CaptionText}"
                                                                   Opacity="0.6"
                                                                   Margin="12,2,0,0"
                                                                   VerticalAlignment="Top"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <TextBlock Text="{Binding [common.importing], Source={StaticResource Loc}}"
                                               Style="{StaticResource CaptionText}"
                                               Foreground="{StaticResource AccentBrush}"
                                               Margin="10,6,10,8"
                                               Visibility="{Binding IsInlineImporting, Converter={StaticResource BoolToVis}}"/>

                                    <Separator Margin="4,4"/>

                                    <Button Style="{StaticResource GhostButton}"
                                            Command="{Binding InlineManualAddCommand}"
                                            Content="{Binding [shell.manualAdd], Source={StaticResource Loc}}"
                                            HorizontalAlignment="Left"
                                            Margin="4,0,0,2"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>

            <!-- Update banner -->
            <Border Grid.Row="1"
                    Margin="20,8,20,0"
                    Style="{StaticResource WarningBanner}"
                    Visibility="{Binding IsUpdateBannerVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding UpdateBannerMessage}"
                               Style="{StaticResource BodyText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="{Binding [common.download], Source={StaticResource Loc}}"
                            Command="{Binding OpenUpdateDownloadCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="0,0,8,0"/>

                    <Button Grid.Column="2"
                            Content="{Binding [common.dismiss], Source={StaticResource Loc}}"
                            Command="{Binding DismissUpdateBannerCommand}"
                            Style="{StaticResource GhostButton}"/>
                </Grid>
            </Border>

            <!-- Content host -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundDarkBrush}"
                    Padding="20,12,20,20">
                <ContentControl x:Name="CurrentViewHost"
                                Content="{Binding CurrentView, NotifyOnTargetUpdated=True}"
                                TargetUpdated="OnCurrentViewChanged"/>
            </Border>
        </Grid>
    </Grid>
</Window>

<Window x:Class="MediaTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MediaTracker.ViewModels"
        xmlns:conv="clr-namespace:MediaTracker.Converters"
        mc:Ignorable="d"
        Title="Media Tracker"
        Height="760"
        Width="1280"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:MediaTypeDisplayConverter x:Key="TypeDisplay"/>

        <!-- Nav link — text only, monospace, no chrome -->
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Padding"     Value="10,7"/>
            <Setter Property="Margin"      Value="0,1"/>
            <Setter Property="Tag"         Value="{Binding DataContext.CurrentSection, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding>
                            <MultiBinding.Converter>
                                <conv:EqualityConverter/>
                            </MultiBinding.Converter>
                            <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                            <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundDarkBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SIDEBAR — text-only, quiet                             -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource BackgroundDarkBrush}">
            <DockPanel Margin="20,28,16,24">

                <!-- Bottom: settings -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Settings"
                            Content="settings"/>
                </StackPanel>

                <!-- Top: brand + navigation -->
                <StackPanel>
                    <!-- Brand — just text, lowercase, monospace -->
                    <TextBlock Text="media tracker"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="{StaticResource FontSizeMedium}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="10,0,0,32"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Home"
                            Content="home"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Library"
                            Content="library"/>

                    <!-- Category label -->
                    <TextBlock Text="categories"
                               Style="{StaticResource PageEyebrowText}"
                               Margin="10,20,0,8"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Series"
                            Content="series"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Anime"
                            Content="anime"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Movies"
                            Content="movies"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Games"
                            Content="games"/>

                    <!-- Curated label -->
                    <TextBlock Text="curated"
                               Style="{StaticResource PageEyebrowText}"
                               Margin="10,20,0,8"/>

                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Favorites"
                            Content="favorites"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CONTENT AREA                                           -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header — very light, no heavy border -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundDarkBrush}"
                    Padding="40,28,40,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentSection}"
                                   Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="{Binding CurrentSectionSubtitle}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <TextBox Grid.Column="1"
                             Width="260"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             Style="{StaticResource SearchBox}"
                             Visibility="{Binding CanSearch, Converter={StaticResource BoolToVis}}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Add button / Inline search toggle -->
                    <Grid Grid.Column="2"
                          VerticalAlignment="Center"
                          Visibility="{Binding CanAddNew, Converter={StaticResource BoolToVis}}">

                        <!-- State 1: "+ add" button (when search is closed) -->
                        <Button Style="{StaticResource AccentButton}"
                                Command="{Binding ToggleInlineSearchCommand}"
                                Content="+ add"
                                Visibility="{Binding IsInlineSearchOpen, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>

                        <!-- State 2: Inline search field (when search is open) -->
                        <Grid Visibility="{Binding IsInlineSearchOpen, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="InlineSearchBox"
                                     Grid.Column="0"
                                     Style="{StaticResource InlineSearchBox}"
                                     Text="{Binding InlineSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="OnInlineSearchKeyDown"
                                     IsVisibleChanged="OnInlineSearchVisible"/>

                            <Button Grid.Column="1"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding CloseInlineSearchCommand}"
                                    Content="esc"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"/>

                            <!-- Dropdown popup anchored below the search box -->
                            <Popup PlacementTarget="{Binding ElementName=InlineSearchBox}"
                                   Placement="Bottom"
                                   IsOpen="{Binding ShowInlineResults}"
                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   PopupAnimation="Fade"
                                   HorizontalOffset="0"
                                   VerticalOffset="4">
                                <Border Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        MinWidth="340"
                                        MaxHeight="420"
                                        Padding="4">
                                    <StackPanel>
                                        <!-- Loading indicator -->
                                        <TextBlock Text="searching..."
                                                   Style="{StaticResource CaptionText}"
                                                   Margin="12,8"
                                                   Visibility="{Binding IsInlineSearching, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Error -->
                                        <TextBlock Text="{Binding InlineError}"
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{StaticResource DangerBrush}"
                                                   Margin="12,8"
                                                   Visibility="{Binding InlineError, Converter={StaticResource NullToVis}}"/>

                                        <!-- Empty state -->
                                        <TextBlock Text="no results found."
                                                   Style="{StaticResource CaptionText}"
                                                   Margin="12,8"
                                                   Visibility="{Binding ShowInlineEmpty, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Results list -->
                                        <ItemsControl ItemsSource="{Binding InlineResults}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource SearchResultButton}"
                                                            Command="{Binding DataContext.InlineImportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Title -->
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Title}"
                                                                       FontFamily="{StaticResource DisplayFont}"
                                                                       FontSize="{StaticResource FontSizeSmall}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="220"/>

                                                            <!-- Year -->
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ReleaseYear}"
                                                                       FontFamily="{StaticResource DisplayFont}"
                                                                       FontSize="{StaticResource FontSizeTiny}"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="10,0,0,0"/>

                                                            <!-- Type + Provider badges -->
                                                            <StackPanel Grid.Column="2"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding MediaType, Converter={StaticResource TypeDisplay}}"
                                                                           FontFamily="{StaticResource DisplayFont}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Margin="8,0,0,0"/>
                                                                <TextBlock Text="{Binding ProviderName}"
                                                                           FontFamily="{StaticResource DisplayFont}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource AccentBrush}"
                                                                           Margin="8,0,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Import loading -->
                                        <TextBlock Text="importing..."
                                                   Style="{StaticResource CaptionText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Margin="12,8"
                                                   Visibility="{Binding IsInlineImporting, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Footer: manual add -->
                                        <Separator Margin="4,4"/>
                                        <Button Style="{StaticResource GhostButton}"
                                                Command="{Binding InlineManualAddCommand}"
                                                Content="add manually"
                                                HorizontalAlignment="Left"
                                                Margin="4,0,0,4"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Subtle separator line -->
            <Border Grid.Row="0"
                    VerticalAlignment="Bottom"
                    Height="1"
                    Background="{StaticResource BorderBrush}"
                    Opacity="0.3"
                    Margin="40,0"/>

            <!-- Update banner -->
            <Border Grid.Row="1"
                    Margin="40,16,40,0"
                    Style="{StaticResource WarningBanner}"
                    Visibility="{Binding IsUpdateBannerVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding UpdateBannerMessage}"
                               Style="{StaticResource BodyText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="download"
                            Command="{Binding OpenUpdateDownloadCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="0,0,8,0"/>

                    <Button Grid.Column="2"
                            Content="dismiss"
                            Command="{Binding DismissUpdateBannerCommand}"
                            Style="{StaticResource GhostButton}"/>
                </Grid>
            </Border>

            <!-- Content host -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundDarkBrush}"
                    Padding="40,24,40,24">
                <ContentControl x:Name="CurrentViewHost"
                                Content="{Binding CurrentView, NotifyOnTargetUpdated=True}"
                                TargetUpdated="OnCurrentViewChanged"/>
            </Border>
        </Grid>
    </Grid>
</Window>
